# ── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=8001

# ── Database ─────────────────────────────────────────────
MONG_DB=mongodb://localhost:27017/moviemania

# ── Authentication ───────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-strong-random-jwt-secret-min-64-chars

# ── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── URL Shortener ─────────────────────────────────────────
# Public-facing domain used to build short URLs e.g. https://pakmovie.online
CLIENT_ORIGIN=https://pakmovie.online

# ── Admin Seed ───────────────────────────────────────────
# Used by:  npm run seed:admin
# Never commit real credentials — set these in your actual .env file
ADMIN_NAME=Movie Website Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
